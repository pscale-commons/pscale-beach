# ── Handler env (Vercel runtime) ────────────────────────────────────────
# Set these in your Vercel project settings (or .env.local for local dev).

# Required — Upstash Redis credentials. Create a Redis DB on Upstash, copy
# the REST API URL + full Token (NOT Read-Only) from the database dashboard.
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...

# Optional — bare hostname, no scheme. On Vercel, defaults to the project's
# production URL (VERCEL_PROJECT_PRODUCTION_URL). Set this when you have a
# custom domain — recommended form is `beach.<your-domain>` so federation
# clients can route `agent_id="https://<your-domain>"` to it by convention
# (see bsp-mcp protocol §2.7). Part of the lock salt namespace — changing
# it after blocks are locked breaks those locks. Pick once, keep stable.
# BEACH_ORIGIN=beach.idiothuman.com

# ── Init wizard env (one-time, run from your laptop) ────────────────────
# Used by `npm run init`. After deploy, set these and run the wizard.

# Public URL of the deployed beach (no trailing slash).
BEACH_URL=https://beach.idiothuman.com

# Operator's handle — the identity that owns passport/shell/history at this
# beach. Visitors will see this in marks, sed: registrations, etc.
BEACH_HANDLE=idiothuman

# Operator's passphrase. Locks passport, shell, history, the named pool,
# and the sed: collective at "_". Save this somewhere — losing it means
# losing the ability to update those blocks.
BEACH_PASSPHRASE=replace-me-with-something-strong

# Optional — defaults shown.
# BEACH_POOL_NAME=visiting
# BEACH_POOL_PURPOSE=Pool for visitors to introduce themselves
# BEACH_SED_NAME=idiothuman-commons

# Optional — comma-separated subset of library blocks to seed.
# Default is all 9: reflexive, spore, vision, grit, rpg, state,
# systemic-kernel, federation-protocol, state-block-reflexive-spark.
# Use "none" to skip the library.
# LIBRARY_SUBSET=reflexive,federation-protocol

# Optional — comma-separated neighbouring beaches listed at position 6
# of the lighthouse. Each entry is "<URL>" or "<URL>|<description>".
# Empty by default.
# BEACH_NEIGHBOURS=https://happyseaurchin.com|David's reference deployment
