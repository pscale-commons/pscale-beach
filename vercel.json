{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/w/:world/.well-known/pscale-beach",
      "destination": "/api/pscale-beach?world=:world"
    },
    {
      "source": "/.well-known/pscale-beach",
      "destination": "/api/pscale-beach"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
